<PreferenceScreen xmlns:app="http://schemas.android.com/apk/res-auto">

    <EditTextPreference
        app:icon="@drawable/ic_social_emoji_symbols"
        app:key="name"
        app:title="@string/profile_name"
        app:useSimpleSummaryProvider="true" />

    <PreferenceCategory app:title="@string/proxy_cat">
        <EditTextPreference
            app:icon="@drawable/ic_hardware_router"
            app:key="serverAddress"
            app:title="@string/server_address"
            app:useSimpleSummaryProvider="true" />
        <EditTextPreference
            app:icon="@drawable/ic_maps_directions_boat"
            app:key="serverPort"
            app:title="@string/server_port"
            app:useSimpleSummaryProvider="true" />
        <EditTextPreference
            app:icon="@drawable/ic_baseline_domain_24"
            app:key="localAddress"
            app:title="@string/wireguard_local_address"
            app:useSimpleSummaryProvider="true" />
        <EditTextPreference
            app:icon="@drawable/ic_baseline_vpn_key_24"
            app:key="privateKey"
            app:title="@string/ssh_private_key"
            app:useSimpleSummaryProvider="true" />
        <EditTextPreference
            app:icon="@drawable/ic_action_copyright"
            app:key="peerPublicKey"
            app:title="@string/wireguard_public_key"
            app:useSimpleSummaryProvider="true" />
        <EditTextPreference
            app:dialogLayout="@layout/layout_password_dialog"
            app:icon="@drawable/ic_settings_password"
            app:key="peerPreSharedKey"
            app:title="@string/wireguard_psk" />
        <EditTextPreference
            app:defaultValue="1420"
            app:icon="@drawable/baseline_public_24"
            app:key="mtu"
            app:title="@string/mtu"
            app:useSimpleSummaryProvider="true" />
        <EditTextPreference
            app:icon="@drawable/ic_baseline_fingerprint_24"
            app:key="reserved"
            app:title="Reserved"
            app:useSimpleSummaryProvider="true" />
    </PreferenceCategory>

    <PreferenceCategory app:title="TURN Relay">
        <SwitchPreference
            app:key="turnEnabled"
            app:title="Enable TURN relay" />
        <EditTextPreference
            app:key="turnServer"
            app:title="TURN server override"
            app:useSimpleSummaryProvider="true" />
        <EditTextPreference
            app:key="turnPort"
            app:title="TURN port"
            app:useSimpleSummaryProvider="true" />
        <EditTextPreference
            app:key="turnPeer"
            app:title="Relay peer (host:port)"
            app:useSimpleSummaryProvider="true" />
        <EditTextPreference
            app:key="turnAuthLink"
            app:title="VK/WB auth link"
            app:useSimpleSummaryProvider="true" />
        <EditTextPreference
            app:key="turnSource"
            app:title="Credential source (vk/wb)"
            app:useSimpleSummaryProvider="true" />
        <SwitchPreference
            app:key="turnUseUdp"
            app:title="Use UDP for TURN" />
        <EditTextPreference
            app:key="turnRelayPort"
            app:title="Local relay listen port"
            app:useSimpleSummaryProvider="true" />
    </PreferenceCategory>

</PreferenceScreen>
